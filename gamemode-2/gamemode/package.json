{
	"name": "arena",
	"version": "1.0.0",
	"scripts": {
		"watch:server": "npx webpack --watch --profile --config ./scripts/webpack.server.js",
		"watch:client": "npx webpack --watch --profile --config ./scripts/webpack.client.js",
		"format-client": "prettier --config .prettierrc \"./source/client/**/*.ts\" --write",
		"format-server": "prettier --config .prettierrc \"./source/server/**/*.ts\" --write",
		"build:all": "npm run build:server && npm run build:client && npm run build:cef",
		"watch:both": "concurrently \"npm run watch:client\" \"npm run watch:server\"",
		"build:server": "npx webpack --profile --config ./scripts/webpack.server.js",
		"build:client": "npx webpack --profile --config ./scripts/webpack.client.js && node scripts/write-client-index.js",
		"watch:cef": "cd ./frontend && npm install && npm run start",
		"build:cef": "cd ./frontend && npm install && npm run build",
		"deploy": "npm run build:all && node scripts/deploy.js",
		"generate:clothes-limits": "node scripts/generateClothesLimits.js --output frontend/src/assets/clothesLimits.generated.json"
	},
	"dependencies": {
		"bufferutil": "^4.0.7",
		"colorette": "^2.0.19",
		"discord-webhook-node": "^1.1.8",
		"dotenv": "^16.0.3",
		"keycode": "^2.2.1",
		"lodash": "^4.17.21",
		"node-cron": "^3.0.2",
		"pg": "^8.11.1",
		"reflect-metadata": "^0.1.14",
		"ts-loader": "^9.4.2",
		"typeorm": "0.3.14",
		"uuid": "^9.0.1",
		"webpack-cli": "^5.0.1",
		"webpack-merge": "^5.8.0",
		"webpack-obfuscator": "^3.5.1",
		"yarn": "^1.22.19"
	},
	"devDependencies": {
		"@ragempcommunity/types-client": "^2.1.6",
		"@ragempcommunity/types-server": "^2.1.6",
		"@types/lodash.clonedeep": "^4.5.7",
		"@types/node": "^20.12.11",
		"@types/uuid": "^9.0.8",
		"concurrently": "^9.1.0",
		"fork-ts-checker-webpack-plugin": "^9.0.2",
		"tsconfig-paths-webpack-plugin": "^4.1.0",
		"typescript": "^5.0.4",
		"webpack": "^5.78.0",
		"webpack-node-externals": "^3.0.0"
	}
}
